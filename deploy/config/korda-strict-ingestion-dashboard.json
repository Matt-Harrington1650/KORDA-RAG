{
  "title": "KORDA Strict Ingestion KPIs",
  "uid": "korda-strict-ingestion",
  "version": 1,
  "schemaVersion": 40,
  "editable": false,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Strict Failure Rate",
      "description": "Failure ratio for strict validation records over $__rate_interval",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(strict_validation_records_total{outcome=\"failure\", job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(strict_validation_records_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])), 0.0001)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "type": "stat",
      "title": "Caption Strict Failure/s",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(strict_validation_records_total{phase=\"caption\", outcome=\"failure\", job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "type": "stat",
      "title": "Summary Strict Failure/s",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(strict_validation_records_total{phase=\"summary\", outcome=\"failure\", job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "type": "stat",
      "title": "Metadata Enrichment Success Rate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(metadata_enrichment_jobs_total{status=\"success\", job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(metadata_enrichment_jobs_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])), 0.0001)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "type": "timeseries",
      "title": "Strict Failures by Error Code",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 4 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (phase, error_code) (rate(strict_validation_records_total{outcome=\"failure\", job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{phase}} / {{error_code}}"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Strict Failure Rate by Document Class",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 4 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (document_class) (rate(strict_validation_records_total{outcome=\"failure\", job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum by (document_class) (rate(strict_validation_records_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])), 0.0001)",
          "legendFormat": "{{document_class}}"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Metadata Enrichment Avg Duration (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(metadata_enrichment_duration_ms_sum{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(metadata_enrichment_duration_ms_count{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])), 0.0001)",
          "legendFormat": "avg"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Metadata Enrichment Jobs/s by Status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "$datasource",
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(metadata_enrichment_jobs_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "refresh": 1,
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": "$datasource",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "query": { "query": "label_values(up, job)", "refId": "StandardVariableQuery" }
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": "$datasource",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "query": {
          "query": "label_values(up{job=~\"$job\"}, instance)",
          "refId": "StandardVariableQuery"
        }
      }
    ]
  },
  "annotations": { "list": [] },
  "links": []
}
